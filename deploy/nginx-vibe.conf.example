# OPCJONALNE - tylko jesli kiedys zechcesz podpiac domene/subdomene
# zamiast wchodzic przez port :8080.
#
# 1. Skopiuj do /etc/nginx/sites-available/vibe-sklep
# 2. Zmien server_name na swoja domene
# 3. ln -s /etc/nginx/sites-available/vibe-sklep /etc/nginx/sites-enabled/
# 4. nginx -t && systemctl reload nginx
# 5. (HTTPS) certbot --nginx -d sklep.twojadomena.pl
#
# UWAGA: nie nadpisuj istniejacych konfigow innych stron na serwerze.

server {
    listen 80;
    server_name sklep.twojadomena.pl;   # <-- ZMIEN

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
